SECRET_KEY=your-super-secret-key-here
# Для генерации хэша: python generate_password.py ваш_пароль
ADMIN_PASSWORD_HASH=pbkdf2:sha256:260000$your-hash-here
DATABASE_URL=sqlite:///freedom_stream.db

# Debug режим (False для production)
FLASK_DEBUG=False

# Порт приложения
PORT=8010

# Уровень логирования (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
